{
  "name": "harmony-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "seed": "dotenv -e .env.local -- tsx scripts/seed.ts",
    "dev": "npm run seed && next dev",
    "build": "next build",
    "start": "npm run seed && next start",
    "lint": "next lint",
    "db:push": "dotenv -e .env.local -- drizzle-kit push:pg",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "monitor": "dotenv -e .env.local -- tsx scripts/crisis-monitor.ts",
    "monitor:install": "dotenv -e .env.local -- tsx scripts/monitor-service-install.ts",
    "monitor:uninstall": "dotenv -e .env.local -- tsx scripts/monitor-service-uninstall.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.5",
    "ai": "^3.2.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.29.1",
    "drizzle-zod": "^0.5.1",
    "face-api.js": "^0.22.2",
    "framer-motion": "^10.16.16",
    "jose": "^5.2.0",
    "lucide-react": "^0.294.0",
    "next": "14.2.3",
    "node-windows": "^1.0.0-beta.8",
    "openai": "^4.104.0",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.2.0",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/node-windows": "^0.1.6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10",
    "dotenv-cli": "^7.4.4",
    "drizzle-kit": "^0.20.2",
    "eslint": "^8",
    "eslint-config-next": "14.2.3",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
