JWT_SECRET=change_me_to_a_long_random_string
# Cloud-routed via Ollama — no local GPU required; requires Ollama ≥ 0.9
OLLAMA_MODEL=gemma4:31b-cloud
OLLAMA_BASE_URL=http://localhost:11434
FASTAPI_BASE_URL=http://127.0.0.1:8000

# Google Gemini — if set, used as the primary "smart" model instead of Ollama.
# Get a key at aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Neon PostgreSQL — get your connection string from console.neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Fast2SMS — sign up free at fast2sms.com, grab your API key
# Free plan supports SMS only. Paid plan enables voice OBD calls.
FAST2SMS_API_KEY=your_fast2sms_api_key_here
